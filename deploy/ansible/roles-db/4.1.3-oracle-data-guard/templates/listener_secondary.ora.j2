ADMIN_RESTRICTIONS_LISTENER = on
LISTENER =
  (ADDRESS_LIST =
        (ADDRESS =
          (PROTOCOL = IPC)
          (KEY = {{ db_sid | upper }}_STDBY.WORLD)
        )
        (ADDRESS=
          (PROTOCOL = IPC)
          (KEY = {{ db_sid | upper }}_STDBY)
        )
        (ADDRESS =
          (PROTOCOL = TCP)
          (HOST = {{ ansible_hostname }})
          (PORT = 1521)
        )
  )
STARTUP_WAIT_TIME_LISTENER = 0
CONNECT_TIMEOUT_LISTENER = 10
TRACE_LEVEL_LISTENER = OFF
SID_LIST_LISTENER =
  (SID_LIST =
    (SID_DESC =
      (SID_NAME = {{ db_sid | upper }}_STDBY)
      (GLOBAL_DBNAME = {{ db_sid | upper }}_STDBY)
    (ORACLE_HOME = /oracle/{{ db_sid | upper }}/{{ ora_release }})
    )
 (SID_DESC =
      (SID_NAME = {{ db_sid }}_STDBY)
      (GLOBAL_DBNAME = {{ db_sid }}_STDBY_DGMGRL)
      (ORACLE_HOME = /oracle/{{ db_sid | upper }}/{{ ora_release }})
    )
  )
ADR_BASE_LISTENER = /oracle/{{ db_sid | upper }}/saptrace
